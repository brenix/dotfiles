# -- ctrl+arrows

"\e[1;5C": forward-word
"\e[1;5D": backward-word
"\eOc": forward-word
"\eOd": backward-word

# -- ctrl+delete

"\e[3;5~": kill-word
"\e[M": kill-word
"\e[3^": kill-word

# -- ctrl+backspace

"\C-h": backward-kill-word

# -- ctrl+shift+delete

"\e[3;6~": kill-line
"\e[3@": kill-line
