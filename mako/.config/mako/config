max-history=5
markup=1
actions=1
history=1
default-timeout=5000
sort=+time

# [ BINDING OPTIONS ]
on-button-left=invoke-default-action
on-button-middle=dismiss-group
on-button-right=dismiss
on-touch=invoke-default-action

# [ STYLE OPTIONS ]
font=GeistMono Nerd Font 11
background-color=#181616
text-color=#C5C9C5

width=320
height=240

margin=10
outer-margin=0
padding=16

border-color=#7FB4CA
border-size=2
border-radius=0

icons=1
max-icon-size=48
icon-location=left

format= <b>%s</b>\n%b
text-alignment=left
max-visible=5
layer=top
anchor=top-right

default-timeout=5000
ignore-timeout=0

