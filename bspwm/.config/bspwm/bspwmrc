#!/bin/zsh

# -- load colors
. "${HOME}/.cache/wal/colors.sh"

# -- kill
killall sxhkd
killall polybar

# -- single-monitor setup

bspc monitor -d 1 2 3 4

# -- multi-monitor setup

# for m in $(xrandr --query | grep " connected" | cut -d" " -f1); do
#   MONITOR=$m polybar main &
# done

