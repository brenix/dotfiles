export BROWSER=google-chrome-unstable
export CLICOLOR=1
export CORRECT_IGNORE_FILE='.*'
export EDITOR=nvim
export GOPATH=~/go
export GREP_COLOR="1;31"
export HISTFILE=~/.zhistory
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export LC_COLLATE="C"
export LOCALE=en_US.UTF-8
export MOZ_DISABLE_PANGO=1
export PAGER="less -iMR"
export VISUAL=nvim
export WORKON_HOME=~/.virtualenvs
export XDG_CONFIG_HOME=~/.config
export XDG_DESKTOP_DIR="/tmp/desktop"
export XDG_DOCUMENTS_DIR="/tmp/docs"
export XDG_DOWNLOAD_DIR="/downloads"
export XDG_MUSIC_DIR="/music"
export XDG_PICTURES_DIR="/tmp/pictures/"
export XDG_PUBLICSHARE_DIR="/tmp/public"
export XDG_TEMPLATES_DIR="/tmp/templates"
export XDG_VIDEOS_DIR="/tmp/videos"
