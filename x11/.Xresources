! -- xft
Xft.dpi:                       92
Xft.antialias:                 true
Xft.autohint:                  false
Xft.hinting:                   true
Xft.hintstyle:                 hintslight
Xft.lcdfilter:                 lcddefault
Xft.rgba:                      rgb

! -- urxvt
URxvt*boldFont:
!URxvt*font:                   xft:Hack Nerd Font Mono:pixelsize=12:antialias=true:style=g
URxvt*font:                    -*-Terminus-*-*-*-*-*-*-*-*-*-*-*-*

URxvt*termName:                rxvt-256color
URxvt.depth:                   32
URxvt*lineSpace:               1
URxvt*letterSpace:             0
URxvt.iso14755:                false
URxvt.iso14755_52:             false
URxvt.scrollBar:               false
URxvt*loginShell:              true
URxvt.internalBorder:          0
URxvt*geometry:                150x35
URxvt.clipboard.autocopy:      true
URxvt.url-launcher:            /usr/bin/google-chrome-unstable
URxvt.matcher.button:          1
URxvt.matcher.rend.0:          Uline Bold fg2
URxvt.cursorBlink:             1
URxvt.cursorUnderline:         1

! -- rofi
rofi.color-enabled:            true
rofi.color-window:             #181818, #181818, #181818
rofi.color-normal:             #0a0b0a, #507057, #0a0b0a, #507057, #a7ecb7
rofi.color-active:             #0a0b0a, #507057, #0a0b0a, #507057, #a7ecb7
rofi.color-urgent:             #0a0b0a, #507057, #0a0b0a, #507057, #a7ecb7
rofi.separator-style:          none
rofi.hide-scrollbar:           true

! colors
#include ".xcolors.d/brenix-hacker"
