configuration {
	bw: 0;
	combi-hide-mode-prefix: true;
	combi-modi: "window,run";
	dpi: 92;
	font: "Terminus 9";
	hide-scrollbar: true;
	line-margin: 1;
	lines: 10;
	modi: "window,run";
	padding: 0;
	separator-style: "solid";
	terminal: "alacritty";
	width: 20;
	window-format: "{c}";
  theme: "~/.cache/wal/colors-rofi-dark.rasi";
}
