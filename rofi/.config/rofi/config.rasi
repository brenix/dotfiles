configuration {
	bw: 0;
	color-active: "#060709, #606778, #060709, #1e2029, #e5e9f0";
	color-normal: "#060709, #606778, #060709, #1e2029, #e5e9f0";
	color-urgent: "#060709, #606778, #060709, #1e2029, #e5e9f0";
	color-window: "#060709, #606778";
	combi-hide-mode-prefix: true;
	combi-modi: "window,run";
	dpi: 91;
	eh: 1;
	font: "Terminus 10";
	hide-scrollbar: true;
	line-margin: 1;
	lines: 10;
	modi: "window,run,combi,calc";
	padding: 0;
	separator-style: "solid";
	terminal: "st";
	width: 20;
	window-format: "{c}";
}
