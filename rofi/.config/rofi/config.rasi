configuration {
	bw: 2;
	combi-hide-mode-prefix: true;
	combi-modi: "window,run";
	dpi: 163;
	font: "Terminus (TTF) 8";
	hide-scrollbar: true;
	line-margin: 1;
	lines: 10;
	modi: "window,run";
	padding: 1;
	separator-style: "solid";
	terminal: "alacritty";
	width: 20;
	window-format: "{c}";
  theme: "~/.cache/wal/colors-rofi-dark.rasi";
}
