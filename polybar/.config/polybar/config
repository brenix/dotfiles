# ---- POLYBAR

[settings]
screenchange-reload = true

[global/wm]
margin-top = 0
margin-bottom = 0

[colors]
background     = "#161821"
foreground     = ${xrdb:color15}
foreground-alt = ${xrdb:color7}
primary        = ${xrdb:color1}
secondary      = ${xrdb:color2}
alert          = ${xrdb:color3}
black          = ${xrdb:color0}
red            = ${xrdb:color1}
green          = ${xrdb:color2}
yellow         = ${xrdb:color3}
blue           = ${xrdb:color4}
magenta        = ${xrdb:color5}
cyan           = ${xrdb:color6}
white          = ${xrdb:color15}
gray           = ${xrdb:color7}

[bar/main]
top = true
monitor = ${env:MONITOR:DVI-I-1}
monitor-fallback = ${env:MONITOR:DVI-D-0}
dpi = 91
height = 16
width = 100%
spacing = 0
separator = %{F#555555}|%{F-}
foreground = ${colors.foreground}
background = ${colors.background}
border-bottom-color = ${colors.black}
border-bottom-size = 1
border-top-color = ${colors.black}
border-top-size = 1
font-0 = xos4 Terminus:pixelsize=14;2
font-1 = Material Icons:size=10;3
font-2 = Hack Nerd Font Mono:size=10;3
font-3 = Weather Icons:size=10;2
module-margin-left = 1
module-margin-right = 1
modules-left = workspaces
modules-center = spotify mpd
modules-right = weather cpu temperature memory volume date time
offset-x = 0
offset-y = 0
padding-left = 1
padding-right = 1

# ---- MODULES

[module/workspaces]
type = internal/xworkspaces
pin-workspaces = false
enable-click = true
enable-scroll = true
label-active-foreground = ${colors.black}
label-active-background = ${colors.blue}
format-padding = 0
format = <label-state>

[module/mpd]
type = internal/mpd
host = 127.0.0.1
port = 6600
interval = 5
label-song =  MPD: %artist% - %title%
click-left = "mpc -q toggle"

[module/spotify]
type = custom/script
interval = 5
format-prefix = " Spotify: "
format = <label>
exec = "python $HOME/.config/polybar/scripts/spotify_status.py -f '{artist} - {song}'"
click-left = "playerctl play-pause"
click-right = "pkill spotify"

[module/temperature]
type = internal/temperature
interval = 3
thermal-zone = 0
warn-temperature = 60
label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${colors.red}
format = <label>
format-prefix = " "
format-prefix-font = 2
format-prefix-foreground = ${colors.foreground}
format-warn = <label-warn>

[module/cpu]
type = internal/cpu
interval = 3
label = %percentage:2%%
format-prefix = " "
format-prefix-foreground = ${colors.foreground}

[module/memory]
type = internal/memory
interval = 30
label = %gb_used%
format-prefix = " "
format-prefix-foreground = ${colors.foreground}

[module/volume]
type = internal/pulseaudio
sink = alsa_output.usb-C-Media_Electronics_Inc._USB_Audio_Device-00.analog-stereo
use-ui-max = false
interval = 5
format-volume = <ramp-volume> <label-volume>
label-volume = %{A3:pavucontrol & disown:}%percentage%%%{A}
label-volume-foreground = ${root.foreground}
label-muted = " %{F#b77a76}MUTED"
label-muted-foreground = ${colors.foreground-alt}
bar-volume-empty-foreground = ${colors.foreground-alt}
ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 

[module/time]
type = internal/date
interval = 5
time = %r
label = %time%
format-prefix = " "
format-prefix-foreground = ${colors.foreground}

[module/date]
type = internal/date
interval = 3600
date = %Y-%m-%d
label = %{A1:gsimplecal & disown:}%{A3:gsimplecal & disown:} %date%%{A}%{A}

[module/weather]
type = custom/script
exec = ~/.config/polybar/scripts/openweathermap-simple.sh
exec-if = ping openweathermap.org -c 1
interval = 600
label-font = 4
click-left = "xdg-open 'https://www.google.com/search?q=weather'"

