# ---- POLYBAR

[settings]
screenchange-reload = true

[global/wm]
margin-top    = 5
margin-bottom = 5

[colors]
background     = #2E3440
foreground     = #D8DEE9
black          = #2E3440
red            = #b77a76
green          = #b4bf86
yellow         = #cbb079
blue           = #83a2be
magenta        = #958090
cyan           = #7daea9
white          = #c5c8c6
gray           = #858585

background-alt = #4c566a
foreground-alt = #e5e9f0

[bar/main]
#monitor          = ${env:MONITOR:}
monitor          = ${env:MONITOR:DVI-I-1}
monitor-fallback = ${env:MONITOR:DVI-D-0}
dpi              = 92

height           = 24
width            = 100%
spacing          = 0

foreground = ${colors.foreground}
background = ${colors.background}

border-bottom-color = ${colors.black}
border-bottom-size  = 1

border-top-color = ${colors.black}
border-top-size  = 0

font-0 = Terminus (TTF):style=Medium:pixelsize=10;2
font-1 = Material Icons:size=12;4
font-2 = unifont:fontformat=truetype:size=8:antialias=false;0
font-3 = "Wuncon Siji:pixelsize=10;1"

module-margin-left  = 2
module-margin-right = 2

modules-left  = workspaces
modules-center = spotify
modules-right = temperature cpu memory volume date time

offset-x = 0
offset-y = 0

padding-left  = 1
padding-right = 1

# wm-restack = bspwm

# ---- MODULES

[module/workspaces]
type = internal/xworkspaces
pin-workspaces = false
enable-click   = true
enable-scroll  = true

label-active   = ""
label-occupied = ""
label-urgent   = ""
label-empty    = ""

label-occupied-padding = 1
label-empty-padding    = 1
label-urgent-padding   = 1
label-active-padding   = 1

label-active-foreground   = ${colors.foreground}
label-occupied-foreground = ${colors.blue}
label-urgent-foreground   = ${colors.red}
label-empty-foreground    = ${colors.foreground}

format-padding = 0
format = <label-state>

[module/bspwm]
type = internal/bspwm
label-focused = %name%
label-focused-background = ${colors.background-alt}
label-focused-padding = 1
label-occupied = %name%
label-occupied-padding = 1
label-urgent = %name%!
label-urgent-background = ${colors.red}
label-urgent-padding = 1
label-empty = %name%
label-empty-foreground = ${colors.foreground-alt}
label-empty-padding = 1

[module/spotify]
type = custom/script
interval = 2
#format-prefix = " SPOTIFY: "
format = <label>
exec = python $HOME/.config/polybar/scripts/spotify_status.py -t 60
click-left = playerctl play-pause

[module/mpd]
type = internal/mpd
host = /run/user/1000/mpd.sock
interval = 2
format-online = " MPD: <label-song>"
label-offline = ""
label-song = %artist% - %title%

[module/temperature]
type = internal/temperature
interval = 3
thermal-zone = 0
warn-temperature = 60

label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${colors.red}

format = <label>
format-prefix = " "
format-prefix-foreground = ${colors.foreground}
format-warn = <label-warn>

[module/cpu]
type = internal/cpu
interval = 3
label = %percentage:2%%
format-prefix = " "
format-prefix-foreground = ${colors.foreground}

[module/memory]
type = internal/memory
interval = 30

label = %gb_used%

format-prefix = " "
format-prefix-foreground = ${colors.foreground}

[module/download]
type = internal/network
interval = 1.5
interface = enp8s0

label-connected = %downspeed%

format-connected-prefix = " "
format-connected-prefix-foreground = ${colors.foreground}

[module/upload]
type = internal/network
interval = 1.5
interface = enp8s0

label-connected = %downspeed%

format-connected-prefix = ""
format-connected-prefix-foreground = ${colors.foreground}

[module/volume]
type = internal/pulseaudio
sink = alsa_output.pci-0000_00_1b.0.analog-stereo
use-ui-max = false
interval = 5

format-volume = <ramp-volume> <label-volume>
label-volume  = %{A3:pavucontrol & disown:}%percentage%%%{A}
label-volume-foreground = ${root.foreground}
label-muted   = " %{F#b77a76}MUTED"
label-muted-foreground = ${colors.foreground-alt}
bar-volume-empty-foreground = ${colors.foreground-alt}
ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 

[module/time]
type = internal/date
interval = 5
time = %r

label = %time%

format-prefix = " "
format-prefix-foreground = ${colors.foreground}

[module/date]
type = internal/date
interval = 3600
date = %Y-%m-%d

label = %{A1:gsimplecal & disown:}%{A3:gsimplecal & disown:} %date%%{A}%{A}

[module/updates]
type = custom/script
exec = ~/bin/getpacmanupdates
interval = 360

format-prefix = " "
format-prefix-foreground = ${colors.foreground}

[module/ip]
type = custom/script
exec = "curl ifconfig.co 2>/dev/null"
interval = 360
format-prefix = " "

[module/vpn]
type = custom/script
exec = "ip link show dev tun0 &>/dev/null && echo Active || echo Inactive"
interval = 60
format-prefix = " "

[module/light]
type = custom/script
exec = ~/bin/lightstatus
interval = 360
click-left = ~/bin/light
format-prefix = " "

[module/filesystem]
type = internal/fs
interval = 25
mount-0 = /

label-mounted =  %mountpoint%%{F-}: %percentage_used%%
label-unmounted =  %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground-alt}

; vim:ft=dosini
