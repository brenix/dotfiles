[global]
font = SF Pro Display 12
markup = yes
plain_text = no
format = "<b>%s</b>\n%b"
sort = no
indicate_hidden = yes
alignment = left
bounce_freq = 0
show_age_threshold = -1
word_wrap = yes
ignore_newline = no
stack_duplicates = yes
hide_duplicates_count = yes
geometry = "300x50-16+51"
shrink = no
transparency = 0
idle_threshold = 0
monitor = 0
follow = none
sticky_history = yes
history_length = 15
show_indicators = no
line_height = 3
separator_height = 2
padding = 5
horizontal_padding = 5
separator_color = frame
startup_notification = false
dmenu = /usr/bin/dmenu -p dunst:
browser = /usr/bin/google-chrome-unstable
icon_position = left
max_icon_size = 32
icon_path = /usr/share/icons/Paper/16x16/mimetypes/:/usr/share/icons/Paper/48x48/status/:/usr/share/icons/Paper/16x16/devices/:/usr/share/icons/Paper/48x48/notifications/:/usr/share/icons/Paper/48x48/emblems/
frame_width = 1
frame_color = "#81a1c1"

[shortcuts]
close = ctrl+space
close_all = ctrl+shift+space
history = ctrl+grave
context = ctrl+shift+period

[urgency_low]
foreground = "#d8dee9"
background = "#161821"
timeout = 4

[urgency_normal]
foreground = "#d8dee9"
background = "#161821"
timeout = 6

[urgency_critical]
foreground = "#bf616a"
background = "#161821"
timeout = 8

