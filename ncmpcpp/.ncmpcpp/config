mpd_host = "/run/user/1000/mpd.sock"
mpd_music_dir = "/mnt/brenix/music/"
ncmpcpp_directory = "~/.ncmpcpp"
ask_before_clearing_playlists = "no"
visualizer_fifo_path = "/tmp/mpd.fifo"
visualizer_output_name = "my_fifo"
visualizer_sync_interval = "30"
visualizer_in_stereo = "yes"
visualizer_type = "spectrum"
visualizer_look = ●▮
progressbar_look = "━━━"
progressbar_elapsed_color = "cyan"
progressbar_color = "black"
playlist_display_mode = "classic"
autocenter_mode = "yes"
centered_cursor = "yes"
user_interface = "classic"
header_visibility = "no"
statusbar_visibility = "no"
visualizer_color = cyan
titles_visibility = "no"
enable_window_title = "yes"
execute_on_song_change = notify-send "Now Playing" "$(mpc --format '%title% \n%artist% - %album%' current)"
state_flags_color = cyan
main_window_color = white
current_item_prefix = $(white)$r
color1 = cyan
color2 = cyan
song_columns_list_format = "(25)[blue]{A} (40)[red]{t|f} (30)[magenta]{b}"
song_list_format = {%A - }{%t}|{$8%f$9}$R{$5$b(%l)$9}
window_border_color = cyan

